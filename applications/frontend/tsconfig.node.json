{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
        "target": "ES2023",
        "lib": ["ES2023"],
        "module": "ESNext",
        "types": ["node"],
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "paths": {
            "@src/*": ["./src/*"]
        }
    },
    "include": ["vite.config.ts"]
}
