{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowImportingTsExtensions": false,
        "noEmit": false,
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "module": "CommonJS",
        "moduleResolution": "Node",
        "verbatimModuleSyntax": false
    },
    "include": ["src/**/*.ts"]
}
