# ── Base de données ───────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword_change_me
DB_PASSWORD=apppassword_change_me

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET=generate_a_strong_secret_here_min_32_chars
FLASK_DEBUG=true

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_strong_jwt_secret_here_min_32_chars

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_prod

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:5000

